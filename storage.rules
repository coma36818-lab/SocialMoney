rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /user_uploads/{userId}/{fileName} {
      allow read: if true; // public posts
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024; // 20MB limit (Spark)
    }
  }
}
