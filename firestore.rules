
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.walletBalance == resource.data.walletBalance
        && request.resource.data.likeBalance == resource.data.likeBalance
        && request.resource.data.totalLikesReceived == resource.data.totalLikesReceived
        && request.resource.data.totalLikesSent == resource.data.totalLikesSent;
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /likeEvents/{eventId} {
      allow write: if false; // Must be handled by a secure backend (Cloud Function)
      allow read: if true; 
    }

    match /transactions/{transactionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Must be created by a secure backend
    }

    match /posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
